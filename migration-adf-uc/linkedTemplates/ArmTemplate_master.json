{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "migration-adf-uc"
		},
		"ls_adls_migration_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://migrationadlsuc.dfs.core.windows.net/"
		},
		"ls_akv_migration_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://migration-kv-uc.vault.azure.net/"
		},
		"ls_azure_sql_migration_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "migration-sql-uc.database.windows.net"
		},
		"ls_azure_sql_migration_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "migration-db"
		},
		"ls_azure_sql_migration_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"trigger_daily_02ist_properties_pl_incremental_ingest_parameters_p_tables_config": {
			"type": "array",
			"defaultValue": [
				{
					"table_name": "olist_sellers_dataset",
					"watermark_col": "created_at"
				}
			]
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "migration-adf-uc_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_migration_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_migration_properties_typeProperties_url')]"
					},
					"ls_akv_migration_properties_typeProperties_baseUrl": {
						"value": "[parameters('ls_akv_migration_properties_typeProperties_baseUrl')]"
					},
					"ls_azure_sql_migration_properties_typeProperties_server": {
						"value": "[parameters('ls_azure_sql_migration_properties_typeProperties_server')]"
					},
					"ls_azure_sql_migration_properties_typeProperties_database": {
						"value": "[parameters('ls_azure_sql_migration_properties_typeProperties_database')]"
					},
					"ls_azure_sql_migration_properties_typeProperties_userName": {
						"value": "[parameters('ls_azure_sql_migration_properties_typeProperties_userName')]"
					},
					"trigger_daily_02ist_properties_pl_incremental_ingest_parameters_p_tables_config": {
						"value": "[parameters('trigger_daily_02ist_properties_pl_incremental_ingest_parameters_p_tables_config')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}